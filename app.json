{
  "expo": {
    "name": "PatrolLink",
    "slug": "PatrolLink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "patrollink",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "googleMapsApiKey": "",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "PatrolLink uses your location to track active patrol routes.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "PatrolLink keeps updating location during active patrols, even in the background.",
        "LSApplicationQueriesSchemes": [
          "tel",
          "telprompt",
          "sms"
        ],
        "UIBackgroundModes": [
          "location",
          "location"
        ]
      },
      "bundleIdentifier": "com.hustlerati.omni"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      },
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CALL_PHONE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": {
            "scheme": "tel"
          }
        },
        {
          "action": "VIEW",
          "data": {
            "scheme": "sms"
          }
        }
      ],
      "package": "com.hustlerati.omni"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.ico"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow PatrolLink to track your patrol location even when the app is in the background.",
          "locationWhenInUsePermission": "Allow PatrolLink to track your location while you are on patrol.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f172a",
          "dark": {
            "backgroundColor": "#0f172a"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "apiUrl": "https://www.omniwatch.hustlerati.com/api",
      "eas": {
        "projectId": "042ee4b7-9832-4e64-9ef9-ae6937a75aaf"
      }
    },
    "owner": "louisotieno2001",
    "description": "PatrolLink is a comprehensive security guard management app designed to streamline operations, enhance communication, and improve safety for security personnel and their supervisors. With features like real-time patrol tracking, incident reporting, and task management, PatrolLink empowers security teams to work more efficiently and effectively."
  }
}
